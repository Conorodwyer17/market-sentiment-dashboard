# =============================================================================
# Market Sentiment Dashboard — Environment Variables
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in NEWSDATA_API_KEY (get free key at newsdata.io)
# 3. Fill in ALPHA_VANTAGE_API_KEY (get free key at alphavantage.co/support/#api-key)
# 4. Run: make up
# That's it. Everything else is pre-configured.
# =============================================================================

# --- REQUIRED: NewsData.io ---
# Free account at: https://newsdata.io
# Click "Get API Key" — no credit card required
# Key format: pub_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEWSDATA_API_KEY=

# --- REQUIRED: Alpha Vantage ---
# Free account at: https://www.alphavantage.co/support/#api-key
# Enter your email and get a key instantly — no credit card
# Key format: XXXXXXXXXXXXXXXX (16 characters)
ALPHA_VANTAGE_API_KEY=

# --- Application (pre-configured, do not change) ---
LOG_LEVEL=INFO

# --- Default assets tracked on startup ---
# Add or remove tickers as you like (comma-separated, no spaces)
DEFAULT_EQUITY_TICKERS=AAPL,MSFT,GOOGL,NVDA,TSLA
DEFAULT_CRYPTO_TICKERS=BTC-USD,ETH-USD
